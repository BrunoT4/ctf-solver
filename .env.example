# Platform: ctfd | picoctf
PLATFORM=ctfd

# CTFd
CTFD_URL=https://ctf.example.com
CTFD_TOKEN=ctfd_your_api_token_here

# picoCTF (export cookies while logged in; JSON object or browser-extension array)
PICO_BASE_URL=https://play.picoctf.org
PICO_COOKIES_FILE=

# Swarm logs + write-ups
LOG_BASE=logs
LOG_RUN_ID=
LOG_TRUNCATE_BYTES=2000
WRITEUP_ENABLED=true
WRITEUP_INCLUDE_FLAG=true
WRITEUP_ON_FAILURE=false
WRITEUP_FORCE=false
WRITEUP_DIR=write-ups
# Optional: provider/model e.g. anthropic/claude-sonnet-4-20250514 or openai/gpt-4o-mini
WRITEUP_MODEL=

# API Keys (at least one required for solving; write-ups need Anthropic or OpenAI)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
